{
  "id": "people",
  "name": "People",
  "version": "0.0.3",
  "enabled": true,
  "nav": {
    "label": "People",
    "icon": "groups",
    "to": "/people"
  },
  "dashboards": [],
  "exports": [
    {
      "id": "PeoplePage",
      "type": "component"
    }
  ],
  "settings": {},
  "service": {
    "url": "http://127.0.0.1:9003",
    "settingPath": "people.satellite_url",
    "spawnModule": "yz_people",
    "autoSpawnSettingPath": "people.satellite_auto_spawn",
    "proxy": {
      "prefix": "/api/people",
      "graceS": 10,
      "timeoutS": 30
    },
    "events": {
      "channels": [
        "people"
      ]
    }
  },
  "requires": {
    "network": "none",
    "sensors": [
      "mic"
    ]
  }
}
